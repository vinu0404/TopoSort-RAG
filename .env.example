# ── LLM API keys ───────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-.....
ANTHROPIC_API_KEY=sk-ant-...

# ── Default model assignments ─────────────────────────────────────────────
MASTER_MODEL_PROVIDER=openai
MASTER_MODEL=gpt-4o

RAG_MODEL_PROVIDER=openai
RAG_MODEL=gpt-4o-mini

CODE_MODEL_PROVIDER=openai
CODE_MODEL=gpt-4o-mini

MAIL_MODEL_PROVIDER=openai
MAIL_MODEL=gpt-4o-mini

WEB_MODEL_PROVIDER=openai
WEB_MODEL=gpt-4o-mini
# ── Tavily (Web Search API) ────────────────────────────────────────────
# Get your key at https://tavily.com → Dashboard → API Keys
TAVILY_API_KEY=tvly-dev-l.......


# ── Security Secrets ──────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-jwt-secret-key
JWT_EXPIRY_SECONDS=604800
OAUTH_STATE_SECRET=change-me-oauth-state
# Generate Fernet key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=encryptmeplease

# ── OAuth Connectors (Web Flow) ──────────────────────────────────────
# 1. Go to https://console.cloud.google.com → APIs & Services → Credentials
# 2. Create an OAuth2 "Web application" client
# 3. Set Authorized redirect URI to: http://localhost:8000/api/v1/connectors/gmail/callback
# 4. Copy the Client ID and Client Secret below
GOOGLE_CLIENT_ID=875618309....com
GOOGLE_CLIENT_SECRET=GOCSPX-Rd...........



OAUTH_REDIRECT_BASE=https://3719-49-200-56-118.ngrok-free.app

# ── GitHub OAuth (GitHub App) ────────────────────────────────────────
# 1. https://github.com/settings/apps → your app → Client ID & Client Secret
# 2. Callback URL: {OAUTH_REDIRECT_BASE}/api/v1/connectors/github/callback
GITHUB_CLIENT_ID=Ov2...................
GITHUB_CLIENT_SECRET=e9381f3fbb5.............

# ── Embedding ──────────────────────────────────────────────────────────────
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536

# ── Qdrant ─────────────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ── Backblaze B2 Cloud Storage (S3-compatible) ────────────────────────────
S3_ENDPOINT=https://s3.us-east-005.backblazeb2.com
S3_REGION=us-east-005
S3_ACCESS_KEY_ID=005241ee.............
S3_SECRET_ACCESS_KEY=K005oBJ....................
S3_BUCKET=linkdrop

# ── PostgreSQL ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/mrag

# ── Server ─────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=true
CORS_ORIGINS=["http://localhost:3000"]

# ── Redis / Celery ─────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
